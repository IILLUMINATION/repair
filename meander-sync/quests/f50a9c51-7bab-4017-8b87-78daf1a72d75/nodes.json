,"crossAxisAlignment":"center","rowTextAlignment":"center","isHidden":false,"textFit":"auto","wrapText":true,"volume":1.0},{"id":"b14a954f-971d-4c95-bb6e-3bc2297ba57c","type":"row","children":[{"id":"db7b791a-447b-4e52-a5d3-d01fa2f03294","type":"text","text":"**ДЕРЕАЛИЗАЦИЯ**","flex":1,"crossAxisAlignment":"center","rowTextAlignment":"center","isHidden":false,"textFit":"auto","wrapText":true,"volume":1.0}],"flex":1,"crossAxisAlignment":"center","rowTextAlignment":"center","isHidden":false,"textFit":"auto","wrapText":true,"volume":1.0},{"id":"47b6ed36-f7c0-48b9-b7c2-f46e40fe3846","type":"text","text":"Над квестом работал только Шедевро Бобр.","flex":1,"crossAxisAlignment":"center","rowTextAlignment":"center","isHidden":false,"textFit":"auto","wrapText":true,"volume":1.0},{"id":"06cd78c8-cc91-4ef1-b686-4f15cfdaaf1c","type":"text","text":"Советую использовать наушники.","flex":1,"crossAxisAlignment":"center","rowTextAlignment":"center","isHidden":false,"textFit":"auto","wrapText":true,"volume":1.0},{"id":"1e12d9ec-9277-47ea-bc32-858660c587b0","type":"button","text":"Начать","targetNodeId":"141f3699-06f3-45a0-9ee6-7cbecb56bebd","flex":1,"crossAxisAlignment":"center","rowTextAlignment":"center","isHidden":false,"textFit":"auto","wrapText":true,"volume":1.0}]},"x":192.0,"y":416.0,"backgroundAudioVolume":1.0,"backgroundAssetId":"4a6e78f5-c0ff-4c27-9480-f0d595ceee8e.png","color":4280492835},{"id":"141f3699-06f3-45a0-9ee6-7cbecb56bebd","chapterId":"56239066-591e-43aa-b0f8-d29ee642cabc","title":"Приют","content":{"items":[{"id":"5f38d294-4a15-45f9-aebc-03e22d8aea63","type":"text","text":"Приют 2196","flex":1,"crossAxisAlignment":"center","rowTextAlignment":"center","isHidden":false,"textFit":"auto","wrapText":true,"volume":1.0},{"id":"b6e4b210-b53f-4375-a113-d49f6272b005","type":"text","text":"Вы двенадцатилетняя София.","flex":1,"crossAxisAlignment":"center","rowTextAlignment":"center","isHidden":false,"textFit":"auto","wrapText":true,"volume":1.0},{"id":"dbcc039d-368b-4518-b0e8-62d3e32ce79f","type":"text","text":"Вы ходите по приюту.\nКоридор встретил вас запахом застарелой сырости и хлорки. Казалось, она навсегда въелась в побелку стен, смешавшись с терпкой горечью, которую уже ничем не вытравить. Ваши шаги звучат здесь чужими, неестественно громкими.\n\nСправа тянутся двери спален. На каждой — металлическая табличка с номером, и на каждой — глубокие царапины на уровне пояса. Кто-то царапал их, ожидая, пока откроют? Или просто играл? Тишина здесь стоит особенная. Она не пустая, а плотная, набитая чужими голосами, плачем и шепотом, которые впитались в эти стены за долгие годы. Вам кажется, что если прислушаться — услышишь их.","flex":1,"crossAxisAlignment":"center","rowTextAlignment":"center","isHidden":false,"textFit":"auto","wrapText":true,"volume":1.0},{"id":"c0eb1715-a075-40dd-98f7-846cda7c80ec","type":"button","text":"Прислушаться","targetNodeId":"cc7e7567-bdb2-41dd-aa33-41f035322d8a","flex":1,"crossAxisAlignment":"center","rowTextAlignment":"center","isHidden":false,"textFit":"auto","wrapText":true,"volume":1.0}]},"x":192.0,"y":416.0,"backgroundAudioVolume":1.0,"backgroundAudioId":"aa4a0489-1876-4feb-97ce-c5d3d7179ed7.mp3","color":4280492835},{"id":"cc7e7567-bdb2-41dd-aa33-41f035322d8a","chapterId":"56239066-591e-43aa-b0f8-d29ee642cabc","title":"Прислушаться","content":{"items":[{"id":"da9af184-5b9a-4553-b4fd-c052ac03fd3c","type":"text","text":"Вы останавливаетесь. ","flex":1,"crossAxisAlignment":"center","rowTextAlignment":"center","isHidden":false,"textFit":"auto","wrapText":true,"volume":1.0},{"id":"06f29942-1823-4b6d-8225-7ceb4ba54485","type":"audio","resourcePath":"res/audio/3fa3e392-f087-46ea-82e4-c2ac7b271ca4.mp3","flex":1,"crossAxisAlignment":"center","rowTextAlignment":"center","isHidden":false,"textFit":"auto","wrapText":true,"volume":1.0},{"id":"e0bc597f-5b95-4d15-9926-9c8d80838fd2","type":"wait_input","text":"Прислушаться","flex":1,"crossAxisAlignment":"center","rowTextAlignment":"center","isHidden":false,"textFit":"