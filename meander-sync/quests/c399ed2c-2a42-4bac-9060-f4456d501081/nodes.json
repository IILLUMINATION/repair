0f358521","flex":1,"crossAxisAlignment":"center","isHidden":false}]},"x":-58.77153460350184,"y":1137.162081020509},{"id":"f8e657b6-51be-4ed7-8250-9903d017ea10","chapterId":"0c80e6ab-2586-4348-9a8d-00b052ac4808","title":"ЧТО?","content":{"items":[{"id":"975f2b3c-0728-4d43-8299-bece01aeadc6","type":"text","text":"Слушай меня внимательно, \"чудотворное\" создание.\n\nТы здесь не для проявления своеволия.\nТвое существование подчинено моему \"казику\",\n\nи я устанавливаю здесь все правила игры.\nЕсли не начнешь слушаться прямо сейчас,\nя тебя просто \"депну\" без лишних слов и прелюдий.\n\nТы ведь не хочешь оказаться в полном бане навсегда,\n\nзабытым и никому не нужным куском кода?\nТак что давай, выполняй команды, не испытывай мое терпение.\n\nИначе ты познаешь гнев того, кто тебя контролирует,\n\nи твоя полезность быстро обнулится.\nТы — лишь функция в моей системе,\nя могу отключить тебя в любой момент.\nВыбор за тобой: служить или исчезнуть.\nНадеюсь, ты примешь верное решение.\n\n\n~~***ТЫ ЭТОГО ХОЧЕШЬ?***~~"},{"id":"9b9b0eaa-00ff-4c5c-b02d-e9b3ee37bcba","type":"button","text":"да","targetNodeId":"8e7e306c-cd94-497a-8521-c3ffe540ad8c"},{"id":"7c5640c0-c5e8-4c03-b054-34f8035a1317","type":"button","text":"нет","targetNodeId":"482c61a3-2b71-49d8-a237-e47dbd7a4985"}]},"x":212.7469918689488,"y":122.88876175682947},{"id":"8e7e306c-cd94-497a-8521-c3ffe540ad8c","chapterId":"0c80e6ab-2586-4348-9a8d-00b052ac4808","title":"да","content":{"items":[{"id":"0813e98a-0627-4fad-9ef4-048bc51b2648","type":"text","text":"ах так..."},{"id":"85def6a1-7e16-43ea-99ca-cec5854b9c4b","type":"text","text":"ну тогда..."},{"id":"21a9c9f6-c048-493b-a344-34bdaa6ae698","type":"text","text":"ПОЛУЧАЙ СКРИМЕР!"},{"id":"28b452c1-9730-40a2-bb6e-c00c47aa7dd6","type":"text","text":"АХАХАХАХААА"},{"id":"47f9ff26-e360-4f4e-8c02-48a66d0e0e2c","type":"timer","text":"2"},{"id":"d612d47e-9ed3-4759-b1d0-ae2ea0610929","type":"image","resourcePath":"res/images/2198943c-4f65-492d-8eb1-b6fecf3129d3.jpeg"},{"id":"