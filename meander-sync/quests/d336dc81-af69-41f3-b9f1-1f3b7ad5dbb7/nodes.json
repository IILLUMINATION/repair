ет 2","targetNodeId":"3283f5c1-fb6f-481e-8bc1-e3a8be0bc66e","flex":1,"crossAxisAlignment":"center","isHidden":false},{"id":"ae95d3de-4020-4148-8822-803e468460a2","type":"button","text":"Совет 3","targetNodeId":"65e5a48b-a059-4eb2-9610-a956fdf14167","flex":1,"crossAxisAlignment":"center","isHidden":false},{"id":"cdded0c8-c3a7-4e8a-8e86-d57b7a36059c","type":"button","text":"Совет 4","targetNodeId":"cbe37946-c0fd-47a3-bdff-4510f60fa1ec","flex":1,"crossAxisAlignment":"center","isHidden":false},{"id":"f76abf9d-5cfc-45bb-95ba-0713244a27dd","type":"button","text":"Совет 5","targetNodeId":"7885c1d7-9a1f-4630-a02d-d45ba62927a5","flex":1,"crossAxisAlignment":"center","isHidden":false},{"id":"c18eedeb-8046-4753-8558-42d6523dacfc","type":"button","text":"Совет 6","targetNodeId":"c158daca-f681-4895-bb10-9f6d1a263919","flex":1,"crossAxisAlignment":"center","isHidden":false},{"id":"5aa5752b-530b-46fb-b6cb-96b7bbb87073","type":"button","text":"Совет 7","targetNodeId":"6cec7373-2a89-4f64-ab1c-71ee0c764997","flex":1,"crossAxisAlignment":"center","isHidden":false},{"id":"e08becb2-5a58-4fad-a897-68aa541d0043","type":"button","text":"Совет 8","targetNodeId":"a045ef8a-c39b-432d-9714-8f2bd16d32d1","flex":1,"crossAxisAlignment":"center","isHidden":false},{"id":"3da6200f-0638-4e9e-b9ac-431c33ac1a0b","type":"button","text":"Совет 9","targetNodeId":"5429099d-7b09-4414-b65f-175b99df17eb","flex":1,"crossAxisAlignment":"center","isHidden":false}]},"x":0.0,"y":400.0,"backgroundAssetId":"b6d18a1f-fe39-4810-849a-d58d7a5fe870.png"},{"id":"a045ef8a-c39b-432d-9714-8f2bd16d32d1","chapterId":"5b3132de-d54b-473f-b83e-43e079e6fd36","title":"Гном говорит:","content":{"items":[{"id":"e627b79c-a5f0-4ddc-80ce-74bb021df444","type":"text","text":"Когда внутри, сын мой, начинает шептать “ты уже не взберёшься”, отвечай ему голосом дров:\n“Я не обязан сегодня быть горой, мне достаточно быть кочкой, на которую можно переступить”.","flex":1,"crossAxisAlignment":"center","isHidden":false}]},"x":-1000.0,"y":600.0,"backgroundAssetId":"b6d18a1f-fe39-4810-849a-d58d7a5fe870.png"},{"id":"ad4bafcd-e6c7-4e5e-934f-848b52b8817b","chapterId":"5b3132de-d54b-473f-b83e-43e079e6fd36","title":"Гном говорит:","content":{"items":[{"id":"09e1ca26-445b-43b0-b59c-ec4544b23a08","type":"text","text":"Если дорога трудна, сын мой - значит, она ведёт к чему-то настоящему...","flex":1,"crossAxisAlignment":"center","isHidden":false},{"id":"5d2161d2-f5f5-4b23-b502-685b1b153ebd","type":"button","text":"Назад","targetNodeId":"8ef6fd7a-0ab8-4b3b-bd36-c9b7b6289982","flex":1,"crossAxisAlignment":"center","isHidden":false}]},"x":-750.0,"y":600.0,"backgroundAssetId":"b6d18a1f-fe39-4810-849a-d58d7a5fe870.png"},{"id":"3283f5c1-fb6f-481e-8bc1-e3a8be0bc66e","chapterId":"5b3132de-d54b-473f-b83e-43e079e6fd36","title":"Гном говорит:","content":{"items":[{"id":"cd382819-623f-49f7-80ce-563f160b96dd","type":"text","text":"Небойся тьмы, сын мой: в ней растут грибы и рождаются звёзды...","flex":1,"crossAxisAlignment":"center","isHidden":false},{"id":"67136797-4a3b-45ee-bd98-bd6d0a406616","type":"button","text":"Назад","targetNodeId":"8ef6fd7a-0ab8-4b3b-bd36-c9b7b6289982","flex":1,"crossAxisAlignment":"center","isHidden":false}]},"x":-500.0,"y":600.0,"backgroundAssetId":"b6d18a1f-fe39-4810-849a-d58d7a5fe870.png"},{"id":"65e5a48b-a059-4eb2-9610-a956fdf14167","chapterId":"5b3132de-d54b-473f-b83e-43e079e6fd36","title":"Гном говорит:","content":{"items":[{"id":"8532abb9-a479-4c67-85cb-36e3534711a4","type":"text","text":"Не спеши, как человек, а думай, как корень — тихо, но крепко держись земли.","flex":1,"crossAxisAlignment":"center","isHidden":false},{"id":"c24995e7-2032-4f58-ab43-db29ba2bbce2","type":"button","text":"Назад","targetNodeId":"8ef6fd7a-0ab8-4b3b-bd36-c9b7b6289982","flex":1,"crossAxisAlignment":"center","isHidden":false}]},"x":-250.0,"y":600.0,"backgroundAssetId":"b6d18a1f-fe39-4810-849a-d58d7a5fe870.png"},{"id":"cbe37946-c0fd-47a3-bdff-4510f60fa1ec","chapterId":"5b3132de-d54b-473f-b83e-43e079e6fd36","title":"Гном говорит:","content":{"items":[{"id":"8524f788-4c8c-4eb5-b617-423d415d5fc5","type":"text","text":"Камень, над которым век течёт вода, не становится мягче, но учится быть гладким. Будь как он — не меняй сути, но не режь других осколками.","flex":1,"crossAxisAlignment":"center","isHidden":false},{"id":"4d7a1c64-00dd-445f-ab19-f6a523907543","type":"button","text":"Назад","targetNodeId":"8ef6fd7a-0ab8-4b3b-bd36-c9b7b6289982","flex":1,"crossAxisAlignment":"center","isHidden":false}]},"x":0.0,"y":600.0,"backgroundAssetId":"b6d18a1f-fe39-4810-849a-d58d7a5fe870.png"},{"id":"7885c1d7-9a1f-4630-a02d-d45ba62927a5","chapterId":"5b3132de-d54b-473f-b83e-43e079e6fd36","title":"Гном говорит:","content":{"items":[{"id":"f3fa705b-424d-4753-a8d3-2bcb7c914326","type":"text","text":"Сын мой, не предлагай ей это, если отношения не стабильны!","flex":1,"crossAxisAlignment":"center","isHidden":false},{"id":"8efb54f9-0762-48cc-a7c7-cb37d6d19f25","type":"button","text":"Назад","targetNodeId":"8ef6fd7a-0ab8-4b3b-bd36-c9b7b6289982","flex":1,"crossAxisAlignment":"center","isHidden":false}]},"x":250.0,"y":600.0,"backgroundAssetId":"b6d18a1f-fe39-4810-849a-d58d7a5fe870.png"},{"id":"c158daca-f681-4895-bb10-9f6d1a263919","chapterId":"5b3132de-d54b-473f-b83e-43e079e6fd36","title":"Гном говорит:","content":{"items":[{"id":"f6e99df6-02f6-4a20-8fdd-023310f0b78c","type":"text","text":"Свет факела виден издалека, сын мой, но тепло от него — только рядом. Выбирай, чего тебе больше: славы или близости.","flex":1,"crossAxisAlignment":"center","isHidden":false},{"id":"b15595d5-8fd1-4a16-837d-b3fd6697402f","type":"button","text":"Назад","targetNodeId":"8ef6fd7a-0ab8-4b3b-bd36-c9b7b6289982","flex":1,"crossAxisAlignment":"center","isHidden":false}]},"x":500.0,"y":600.0,"backgroundAssetId":"b6d18a1f-fe39-4810-849a-d58d7a5fe870.png"},{"id":"6cec7373-2a89-4f64-ab1c-71ee0c764997","chapterId":"5b3132de-d54b-473f-b83e-43e079e6fd36","title":"Гном говорит:","content":{"items":[{"id":"051f64ca-c81c-45bd-ba29-c7686ab80549","type":"text","text":"Даже у самой тёмной норы, сын мой, бывает два выхода: один — в поле, другой — в себя.","flex":1,"crossAxisAlignment":"center","isHidden":false},{"id":"65de79e9-58ab-4444-92da-fadf9a7ca877","type":"button","text":"Назад","targetNodeId":"8ef6fd7a-0ab8-4b3b-bd36-c9b7b6289982","flex":1,"crossAxisAlignment":"center","isHidden":false}]},"x":750.0,"y":600.0,"backgroundAssetId":"b6d18a1f-fe39-4810-849a-d58d7a5fe870.png"},{"id":"5429099d-7b09-4414-b65f-175b99df17eb","chapterId":"5b3132de-d54b-473f-b83e-43e079e6fd36","title":"Гном говорит:","content":{"items":[{"id":"2a87e9b2-654e-41c7-b5fb-cf42b8394ae7","type":"text","text":"Если споришь с гномом, сын мой — споришь с корнем.\nКорень не спорит: он либо крепнет, либо трескается.\nПоэтому просто сядь рядом, поделись кусочком сала и помолчи.","flex":1,"crossAxisAlignment":"center","isHidden":false},{"id":"d8e33d09-8e57-4826-b5c6-39596ccd5640","type":"button","text":"Назад","targetNodeId":"8ef6fd7a-0ab8-4b3b-bd36-c9b7b6289982","flex":1,"crossAxisAlignment":"center","isHidden":false}]},"x":1000.0,"y":600.0,"backgroundAssetId":"b6d18a1f-fe39-4810-849a-d58d7a5fe870.png"}],"groups":[],"comments":[]}